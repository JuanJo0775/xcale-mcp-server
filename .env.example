# xcale-mcp-server — environment.
# Real secrets live in Doppler, NEVER in a committed .env. This file documents the shape only.

# Hop B — how a consumer (e.g. xcale-backend) authenticates TO this server (shared secret).
MCP_SERVER_SECRET=replace-me-in-doppler

# HTTP
PORT=8080
NODE_ENV=development

# Logging (pino)
LOG_LEVEL=info
