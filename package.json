{
  "name": "xcale-mcp-server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "xcale's own MCP integration platform (a 'Composio LATAM'). Provider knowledge lives here; consumers consume capabilities over stable, consumer-agnostic MCP contracts.",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "tsx watch src/server.ts",
